    {
      "type": "timeseries",
      "title": "HTTP requests / sec",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(acp_http_requests_total[5m])) by (path, status_code)",
          "legendFormat": "{{path}} {{status_code}}"
        }
      ]
    },
