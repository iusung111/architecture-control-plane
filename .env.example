DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/control_plane
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_CONNECT_TIMEOUT_SECONDS=5
DB_STATEMENT_TIMEOUT_MS=30000
DB_IDLE_IN_TRANSACTION_SESSION_TIMEOUT_MS=60000
LLM_PROVIDER=disabled
LLM_USAGE_MODE=free_only
LLM_USAGE_COUNTER_BACKEND=auto
LLM_USAGE_REDIS_URL=
LLM_USAGE_REDIS_KEY_PREFIX=acp:llm:usage
LLM_FREE_DAILY_REQUESTS_OPENAI=0
LLM_FREE_DAILY_REQUESTS_GEMINI=1000
LLM_FREE_DAILY_REQUESTS_GROK=0
LLM_FREE_DAILY_REQUESTS_CLAUDE=0
LLM_FREE_DAILY_REQUESTS_CLOUDFLARE_WORKERS_AI=25
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.5-flash-lite
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-4
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.anthropic.com/v1/messages
CLAUDE_MODEL=claude-3-5-haiku-latest
CLAUDE_API_VERSION=2023-06-01
CLAUDE_MAX_TOKENS=2048
CLAUDE_BETA=
CLOUDFLARE_AI_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_BASE_URL=
CLOUDFLARE_AI_MODEL=@cf/openai/gpt-oss-120b
APPROVAL_EXPIRY_HOURS=24
ENVIRONMENT=development
LOG_LEVEL=INFO
AUTH_MODE=header
AUTH_HEADER_FALLBACK_ENABLED=true
AUTH_JWT_SECRET=
# Optional file-backed secret loading:
# AUTH_JWT_SECRET_FILE=/var/run/acp-secrets/AUTH_JWT_SECRET
# DATABASE_URL_FILE=/var/run/acp-secrets/DATABASE_URL
# MANAGEMENT_API_KEYS_JSON_FILE=/var/run/acp-secrets/MANAGEMENT_API_KEYS_JSON
# SECRETS_DIR=/var/run/acp-secrets
AUTH_JWKS_URL=
AUTH_OIDC_DISCOVERY_URL=
AUTH_OIDC_DISCOVERY_CACHE_TTL_SECONDS=300
AUTH_OIDC_REQUIRE_HTTPS=true
AUTH_JWKS_CACHE_TTL_SECONDS=300
# AUTH_MODE=bearer_jwt -> use HS256,HS384,HS512
# AUTH_MODE=oidc_jwks -> use RS256,RS384,RS512,ES256,ES384,ES512,EdDSA
AUTH_JWT_ALLOWED_ALGORITHMS=HS256
AUTH_JWT_LEEWAY_SECONDS=30
MANAGEMENT_API_KEY=
MANAGEMENT_ENDPOINTS_REQUIRE_API_KEY=false
METRICS_ENABLED=true
WORKER_METRICS_ENABLED=true
API_AVAILABILITY_SLO_TARGET=0.995
API_LATENCY_SLO_TARGET=0.95
API_LATENCY_SLO_SECONDS=1.0
OTEL_ENABLED=false
OTEL_SERVICE_NAME=
OTEL_SERVICE_NAMESPACE=architecture-control-plane
OTEL_SERVICE_VERSION=0.1.0
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_TRACES_SAMPLER_RATIO=1.0
AUTH_JWT_ISSUER=architecture-control-plane
AUTH_JWT_AUDIENCE=architecture-control-plane-api
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_TIMEOUT_SECONDS=5
ALERTMANAGER_DEFAULT_EMAIL_TO=team@example.com
ALERTMANAGER_SMTP_FROM=architecture-control-plane-alerts@example.local
ALERTMANAGER_SMTP_SMARTHOST=mailpit:1025
ALERTMANAGER_SMTP_REQUIRE_TLS=false
ALERTMANAGER_SMTP_AUTH_USERNAME=
ALERTMANAGER_SMTP_AUTH_PASSWORD=
ALERTMANAGER_WEBHOOK_URL=http://webhook-sink:8081/alertmanager

NOTIFICATION_WEBHOOK_SIGNING_SECRET=replace-with-strong-shared-secret
NOTIFICATION_WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

ABUSE_PROTECTION_ENABLED=true
ABUSE_RATE_LIMIT_BACKEND=in_memory
ABUSE_RATE_LIMIT_ALGORITHM=fixed_window
ABUSE_RATE_LIMIT_BURST_MULTIPLIER=1.0
ABUSE_RATE_LIMIT_BACKEND_FAILURE_MODE=open
ABUSE_RATE_LIMIT_BACKEND_FAILURE_MODE_API=open
ABUSE_RATE_LIMIT_BACKEND_FAILURE_MODE_MANAGEMENT=closed
ABUSE_METRICS_INCLUDE_TENANT_LABELS=false
ABUSE_METRICS_TENANT_LABEL_MODE=hashed
ABUSE_RATE_LIMIT_BACKEND_FAILURE_RETRY_AFTER_SECONDS=5
ABUSE_REDIS_URL=redis://localhost:6379/0
ABUSE_REDIS_KEY_PREFIX=acp:ratelimit
ABUSE_REDIS_SOCKET_TIMEOUT_SECONDS=1
ABUSE_REDIS_CONNECT_TIMEOUT_SECONDS=1
ABUSE_REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30
ABUSE_GLOBAL_REQUESTS_PER_MINUTE=240
ABUSE_MANAGEMENT_REQUESTS_PER_MINUTE=60
ABUSE_CYCLE_CREATE_LIMIT_PER_MINUTE=30
ABUSE_CYCLE_RETRY_LIMIT_PER_MINUTE=20
ABUSE_CYCLE_REPLAN_LIMIT_PER_MINUTE=20
ABUSE_APPROVAL_CONFIRM_LIMIT_PER_MINUTE=30
ABUSE_TENANT_PLAN_DEFAULT=standard
ABUSE_TENANT_PLAN_ASSIGNMENTS_JSON={"tenant-free":"free","tenant-pro":"pro"}
ABUSE_TENANT_PLAN_LIMITS_JSON={"free":{"global_request":120,"cycle_create":10,"cycle_retry":5,"cycle_replan":5,"approval_confirm":10},"pro":{"global_request":480,"cycle_create":60,"cycle_retry":40,"cycle_replan":40,"approval_confirm":60}}

# Backup / restore drill
